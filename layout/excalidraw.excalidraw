    {
      "id": "_yiYnF6chzWq_ZBuy-LrC",
      "type": "text",
      "x": -2260.6604056564183,
      "y": 543.6388888888888,
      "width": 632.4196166992188,
      "height": 375,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
